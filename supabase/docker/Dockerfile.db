FROM pgvector/pgvector:pg15

USER root

RUN apt-get update && apt-get install -y \
  build-essential \
  postgresql-server-dev-15 \
  git \
  libcurl4-openssl-dev \
  && rm -rf /var/lib/apt/lists/*

# Build pg_cron
RUN cd /tmp && git clone --branch v1.6.4 https://github.com/citusdata/pg_cron.git \
  && cd pg_cron && make && make install \
  && cd / && rm -rf /tmp/pg_cron

# Build pg_net (autonomous webhook layer: cron -> net.http_post). Needs libcurl.
RUN cd /tmp && git clone --branch v0.14.0 https://github.com/supabase/pg_net.git \
  && cd pg_net && make && make install \
  && cd / && rm -rf /tmp/pg_net

# Build pgjwt
RUN cd /tmp && git clone https://github.com/michelp/pgjwt.git \
  && cd pgjwt && make && make install \
  && cd / && rm -rf /tmp/pgjwt

# Cleanup build tools (keep libcurl runtime for pg_net)
RUN apt-get purge -y build-essential postgresql-server-dev-15 git \
  && apt-get autoremove -y \
  && rm -rf /var/lib/apt/lists/*

USER postgres
