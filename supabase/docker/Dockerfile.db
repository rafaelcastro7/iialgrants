FROM pgvector/pgvector:pg15

USER root

RUN apt-get update && apt-get install -y \
  build-essential \
  postgresql-server-dev-15 \
  git \
  && rm -rf /var/lib/apt/lists/*

# Build pg_cron
RUN cd /tmp && git clone --branch v1.6.4 https://github.com/citusdata/pg_cron.git \
  && cd pg_cron && make && make install \
  && cd / && rm -rf /tmp/pg_cron

# Build pgjwt
RUN cd /tmp && git clone https://github.com/michelp/pgjwt.git \
  && cd pgjwt && make && make install \
  && cd / && rm -rf /tmp/pgjwt

# Cleanup build tools
RUN apt-get purge -y build-essential postgresql-server-dev-15 git \
  && apt-get autoremove -y \
  && rm -rf /var/lib/apt/lists/*

USER postgres
